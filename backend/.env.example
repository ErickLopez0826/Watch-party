# Puerto donde corre el servidor (Railway/Render lo inyectan automáticamente)
PORT=3001

# Origen del frontend en producción — DEBE coincidir exactamente con tu dominio
# Ejemplo: https://watchparty.up.railway.app
# Si no se configura, CORS acepta cualquier origen (solo válido en desarrollo local)
FRONTEND_URL=https://tu-dominio.com

# Ruta absoluta donde se guarda la base de datos SQLite
# En Railway/Render usar un volumen persistente, ej: /data/watch_party.db
# Si no se configura, se guarda en ../../data/watch_party.db relativo al ejecutable
# DATABASE_PATH=/data/watch_party.db

# Entorno de ejecución — en producción el backend sirve el build del frontend
NODE_ENV=production
